@startuml
!pragma layout smetana

title Phase 1 - Baseline (Bankruptcy + Medical)

left to right direction
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho
skinparam nodesep 64
skinparam ranksep 68
skinparam ArrowThickness 1.6
skinparam ArrowColor #444444
skinparam packageStyle rectangle
skinparam rectangle {
  roundCorner 14
}
skinparam database {
  BackgroundColor #E8F4FF
  BorderColor #2E5A88
}

database "Datasets\n- Bankruptcy (US fyear)\n- Medical (Diabetes 130-US, 1999-2008)" as DS
rectangle "Year-based split iterator\nOld / New / Test\n(Bankruptcy: 15 splits; Medical: 7 splits)" as SPLIT
rectangle "Preprocessing\nhandle_missing_values\ncategorical cleanup / feature alignment" as PREP

database "Old" as OLD
database "New" as NEW
database "Test" as TEST

DS --> SPLIT
SPLIT --> PREP
PREP --> OLD
PREP --> NEW
PREP --> TEST

package "Training regime" as PKG_T #FFFACD {
  rectangle "Old model" as T_OLD
  rectangle "New model" as T_NEW
  rectangle "Retrain model\n(Old + New)" as T_ALL
}
T_OLD -[hidden]right- T_NEW
T_NEW -[hidden]right- T_ALL
OLD --> T_OLD
NEW --> T_NEW
OLD --> T_ALL
NEW --> T_ALL

package "Sampling strategy" as PKG_S #FFFACD {
  rectangle "none" as S0
  rectangle "undersampling" as S1
  rectangle "oversampling" as S2
  rectangle "hybrid" as S3
}
S0 -[hidden]right- S1
S1 -[hidden]right- S2
S2 -[hidden]right- S3

package "Classifier family" as PKG_C #E0E0E0 {
  rectangle "XGBoost" as C_XGB
  rectangle "LightGBM" as C_LGB
  rectangle "Random Forest" as C_RF
  rectangle "Logistic Regression" as C_LR
  rectangle "Torch MLP" as C_TMLP
  rectangle "FT-Transformer" as C_FT
  rectangle "TabM" as C_TABM
  rectangle "TabICL" as C_TABICL
}

rectangle "Validation-based threshold search\nmaximize F1 (grid over probability threshold)" as THR #FFFACD
rectangle "Test inference\nfixed threshold from validation" as INF #F5F5F5
rectangle "Metrics\nAUC / F1 / Recall / Precision\nType1_Error / Type2_Error" as EVAL #FFFFFF

T_OLD --> PKG_S
T_NEW --> PKG_S
T_ALL --> PKG_S
PKG_S --> PKG_C
PKG_C --> THR
TEST --> INF
THR --> INF
INF --> EVAL

@enduml
