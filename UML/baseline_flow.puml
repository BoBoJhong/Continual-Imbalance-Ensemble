@startuml
!pragma layout smetana

title Phase 1 — Baseline

left to right direction
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 72
skinparam ArrowThickness 1.6
skinparam ArrowColor #444444
skinparam packageStyle rectangle
skinparam rectangle {
  roundCorner 14
}
skinparam database {
  BackgroundColor #E8F4FF
  BorderColor #2E5A88
}

database "Dataset\n(US fyear)" as DS
rectangle "Rolling\nyear split\n× 15 folds\n(New>=1yr)" as CUT
DS --> CUT

database "Old" as OLD
database "New" as NEW
database "Test\n(2015–2018\nfixed)" as TE

CUT --> OLD
CUT --> NEW
CUT --> TE



package "Training setup" as PKG_B #FFFACD {
  rectangle "Train on\nOld" as B1
  rectangle "Train on\nNew" as B2
  rectangle "Retrain on\nAll" as B3
}

B1 -[hidden]right- B2
B2 -[hidden]right- B3

OLD --> B1
NEW --> B2
OLD --> B3
NEW --> B3


package "Sampling strategy" as PKG_S #FFFACD {
  rectangle "None" as S0
  rectangle "Under" as S1
  rectangle "Over" as S2
  rectangle "Hybrid" as S3
}

S0 -[hidden]right- S1
S1 -[hidden]right- S2
S2 -[hidden]right- S3

package "Classifier" as PKG_C #E0E0E0 {
  rectangle "XGBoost" as CLF_XGB
  rectangle "Logistic Regression" as CLF_LR
  rectangle "Random Forest" as CLF_RF
  rectangle "Torch MLP" as CLF_TMLP
  rectangle "FT-Transformer" as CLF_FT
}

CLF_XGB -[hidden]right- CLF_LR
CLF_LR -[hidden]right- CLF_RF
CLF_RF -[hidden]right- CLF_TMLP
CLF_TMLP -[hidden]right- CLF_FT

rectangle "Threshold tuning\n(Val F1)" as THR #FFFACD
rectangle "Test inference\n(apply threshold)" as INF #F5F5F5
rectangle "Evaluation\nAUC / F1 / Recall" as OUT #FFFFFF

database "Val pool" as VAL

B1 --> PKG_S
B2 --> PKG_S
B3 --> PKG_S

PKG_S --> PKG_C

PKG_C --> THR

B1 ..> VAL : Old
B2 ..> VAL : New
B3 ..> VAL : All
VAL --> THR


THR --> INF
TE --> INF
INF --> OUT
@enduml