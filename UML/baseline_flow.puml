@startuml
!pragma layout smetana

title Phase 1 — Baseline（破產 US：年份切割 + 四策略）

left to right direction
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 72
skinparam ArrowThickness 1.6
skinparam ArrowColor #444444
skinparam packageStyle rectangle
skinparam rectangle {
  roundCorner 14
}
skinparam database {
  BackgroundColor #E8F4FF
  BorderColor #2E5A88
}

database "Dataset\n(US fyear)" as DS
rectangle "Rolling\nyear split\n× 14 folds" as CUT
DS --> CUT

database "Old" as OLD
database "New" as NEW
database "Test\n(2015–2018\nfixed)" as TE

CUT --> OLD
CUT --> NEW
CUT --> TE



package "Training setup" as PKG_B #FFFACD {
  rectangle "Train on\nOld" as B1
  rectangle "Train on\nNew" as B2
  rectangle "Retrain on\nOld + New\n(全訓練窗)" as B3
  rectangle "Fine-tune\nOld → New" as B4
}

B1 -[hidden]right- B2
B2 -[hidden]right- B3
B3 -[hidden]right- B4

OLD --> B1
NEW --> B2
OLD --> B3
NEW --> B3
OLD --> B4
NEW --> B4


package "Sampling strategy" as PKG_S #FFFACD {
  rectangle "None" as S0
  rectangle "Under" as S1
  rectangle "Over" as S2
  rectangle "Hybrid" as S3
}

S0 -[hidden]right- S1
S1 -[hidden]right- S2
S2 -[hidden]right- S3

package "Classifier\n(同流程可替換)" as PKG_C #E0E0E0 {
  rectangle "XGBoost" as XGB
  rectangle "LR / RF /\nTorch MLP /\nFT-Transformer" as OTH
}

XGB -[hidden]right- OTH

rectangle "Threshold tuning\n(max Val F1)" as THR #FFFACD
rectangle "Test inference\n(apply threshold)" as INF #F5F5F5
rectangle "Evaluation\nAUC / F1 / Recall" as OUT #FFFFFF

rectangle "Validation pool\n(per fyear ~20%\nwithin train)" as VAL #E8F4FF

B1 --> PKG_S
B2 --> PKG_S
B3 --> PKG_S
B4 --> PKG_S

PKG_S --> XGB
PKG_S --> OTH

XGB --> THR
OTH --> THR

OLD ..> VAL : Old-only /\nFinetune
NEW ..> VAL : New-only /\nFinetune
VAL --> THR


THR --> INF
TE --> INF
INF --> OUT
@enduml
