@startuml
!pragma layout smetana

title Phase 1 - Baseline

left to right direction
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 72
skinparam ArrowThickness 1.6
skinparam ArrowColor #444444
skinparam packageStyle rectangle
skinparam rectangle {
  roundCorner 14
}
skinparam database {
  BackgroundColor #E8F4FF
  BorderColor #2E5A88
}

database "DATASET" as DS
rectangle "Time\nsplit" as CUT
DS --> CUT

database "Old" as OLD
database "New" as NEW
database "Test" as TE

CUT --> OLD
CUT --> NEW
CUT --> TE

package "Train setup" as PKG_B #FFFACD {
  rectangle "Old\nonly" as B1
  rectangle "New\nonly" as B2
  rectangle "Old+New\nretrain" as B3
  rectangle "Old→New\nfinetune" as B4
}

B1 -[hidden]right- B2
B2 -[hidden]right- B3
B3 -[hidden]right- B4

OLD --> B1
NEW --> B2
OLD --> B3
NEW --> B3
OLD --> B4
NEW --> B4

package "Sampling" as PKG_S #FFFACD {
  rectangle "none" as S0
  rectangle "under" as S1
  rectangle "over" as S2
  rectangle "hybrid" as S3
}

S0 -[hidden]right- S1
S1 -[hidden]right- S2
S2 -[hidden]right- S3

package "Classifier" as PKG_C #E0E0E0 {
  rectangle "XGB" as XGB
  rectangle "…" as MORE
}

XGB -[hidden]right- MORE

rectangle "Thr\nVal F1" as THR #FFFACD

B1 --> PKG_S
B2 --> PKG_S
B3 --> PKG_S
B4 --> PKG_S
PKG_S --> XGB
XGB --> THR

database "Val" as VAL
NEW .. VAL
VAL --> THR

rectangle "AUC / F1 / Recall" as OUT #FFFFFF
TE --> OUT
THR --> OUT

@enduml
