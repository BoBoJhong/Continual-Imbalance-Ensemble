@startuml
!pragma layout smetana

title Phase 1 — Baseline

left to right direction
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 72
skinparam ArrowThickness 1.6
skinparam ArrowColor #444444
skinparam packageStyle rectangle
skinparam rectangle {
  roundCorner 14
}
skinparam database {
  BackgroundColor #E8F4FF
  BorderColor #2E5A88
}

database "Dataset" as DS
rectangle "Time\nsplit" as CUT
DS --> CUT

database "Old" as OLD
database "New" as NEW
database "Test" as TE

CUT --> OLD
CUT --> NEW
CUT --> TE

package "Training setup" as PKG_B #FFFACD {
  rectangle "Train on\nOld" as B1
  rectangle "Train on\nNew" as B2
  rectangle "Retrain on\nOld + New" as B3
  rectangle "Fine-tune\nOld → New" as B4
}

B1 -[hidden]right- B2
B2 -[hidden]right- B3
B3 -[hidden]right- B4

OLD --> B1
NEW --> B2
OLD --> B3
NEW --> B3
OLD --> B4
NEW --> B4

package "Sampling strategy" as PKG_S #FFFACD {
  rectangle "None" as S0
  rectangle "Under" as S1
  rectangle "Over" as S2
  rectangle "Hybrid" as S3
}

S0 -[hidden]right- S1
S1 -[hidden]right- S2
S2 -[hidden]right- S3

package "Classifier" as PKG_C #E0E0E0 {
  rectangle "XGBoost" as XGB
  rectangle "MLP" as MLP
}

XGB -[hidden]right- MLP

rectangle "Threshold tuning\n(max Val F1)" as THR #FFFACD
rectangle "Test inference\n(apply threshold)" as INF #F5F5F5
rectangle "Evaluation\nAUC / F1 / Recall" as OUT #FFFFFF

database "Validation\n(from New)" as VAL

B1 --> PKG_S
B2 --> PKG_S
B3 --> PKG_S
B4 --> PKG_S

PKG_S --> XGB
PKG_S --> MLP

XGB --> THR
MLP --> THR

NEW ..> VAL
VAL --> THR

THR --> INF
TE --> INF
INF --> OUT
@enduml