@startuml
!pragma layout smetana
title Ensemble Learning Framework — Static and Dynamic (DCS / DES)

left to right direction
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho
skinparam nodesep 24
skinparam ranksep 42
skinparam packageStyle rectangle
skinparam rectangle {
  roundCorner 12
}
skinparam database {
  BackgroundColor #E8F4FF
  BorderColor #2E5A88
}

rectangle "Ensemble\nLearning" as E
rectangle "Static\nEnsemble" as ST #E0E0E0
rectangle "Dynamic\nSelection (DCS / DES)" as DY #D7E8F0
E --> ST
E --> DY

database "Old\ndataset" as OLD
database "New\ndataset" as NEW
ST --> OLD
ST --> NEW
DY --> OLD
DY --> NEW

package "Old model pool" as PKG_O #FFFACD {
  rectangle "O1\nunder" as O1
  rectangle "O2\nover" as O2
  rectangle "O3\nhybrid" as O3
}

package "New model pool" as PKG_N #FFFACD {
  rectangle "N1\nunder" as N4
  rectangle "N2\nover" as N5
  rectangle "N3\nhybrid" as N6
}

OLD --> O1
OLD --> O2
OLD --> O3
NEW --> N4
NEW --> N5
NEW --> N6

package "Static ensemble subsets" as PKG_C #E8E8E8 {
  rectangle "2 models\n(1O + 1N)" as CA #E8F5E9
  rectangle "3 models\n(2O+1N / 1O+2N)" as CB #E3F2FD
  rectangle "4 models" as CC #FCE4EC
  rectangle "5 models" as CD #FFF3E0
  rectangle "6 models\n(all)" as CE #ECEFF1
}

CA -[hidden]right- CB
CB -[hidden]right- CC
CC -[hidden]right- CD
CD -[hidden]right- CE

PKG_O --> PKG_C : old candidates
PKG_N --> PKG_C : new candidates

rectangle "Static fusion\n(mean probability)\nVal-tuned threshold" as FUS #D8D8D8

CA --> FUS
CB --> FUS
CC --> FUS
CD --> FUS
CE --> FUS

database "Validation\nset" as VAL
database "Test\nset" as TE
rectangle "Evaluation\nAUC / F1 / Recall" as OUT #FFFFFF

VAL --> FUS
TE --> FUS
FUS --> OUT

package "Dynamic pipeline" as PKG_DY #E3F2FD {
  rectangle "DSEL\nOld + New merged\n(New-scaler space)" as DSEL #FFFFFF
  rectangle "k-NN\nk = 7" as KNN #FFFFFF

  package "DES methods" as PKG_DES #E8F5E9 {
    rectangle "KNORA-E" as DE1
    rectangle "KNORA-U" as DE2
    rectangle "DES-KNN" as DE3
  }

  package "DCS methods" as PKG_DCS #FFF8E1 {
    rectangle "OLA / LCA" as DC1
    rectangle "OLA_TW /\nLCA_TW" as DC2
  }

  rectangle "Per-instance\nselection / weighting\n+ Val-tuned threshold" as DYNFUS #D8E8F0
}

PKG_O ..> DSEL : 6 base models
PKG_N ..> DSEL
DSEL --> KNN
KNN --> PKG_DES
KNN --> PKG_DCS
DE1 --> DYNFUS
DE2 --> DYNFUS
DE3 --> DYNFUS
DC1 --> DYNFUS
DC2 --> DYNFUS

VAL ..> DYNFUS
TE ..> DYNFUS
DYNFUS --> OUT
@enduml